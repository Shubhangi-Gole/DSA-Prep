
class Solution:
    def isSymmetric(self, root: Optional[TreeNode]) -> bool:
        def chk(a,b):
            if (a==None and b==None):
                return True
            if (a==None or b==None):
                return False
            return (a.val==b.val) and chk(a.left,b.right) and chk(a.right,b.left)
        return chk(root,root)            
        
